# Ignore everything in the plural projects folder
public/projects/**/*

# Allow the directory structure itself
!public/projects/**/
public/projects/ToSort

# Allow only the small metadata and optimized assets
!public/projects/**/*.webp
!public/projects/**/*.json

# --- Environment Secrets ---
.env

